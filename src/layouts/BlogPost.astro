---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FallbackImage from '../assets/blog-placeholder-about.jpg';

type PostNavItem = { id: string; title: string };

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: import('astro').ImageMetadata;
	category?: string;
	views: number;
	prev?: PostNavItem;
	next?: PostNavItem;
};

const { title, description, pubDate, heroImage, category, views, prev, next } = Astro.props;

const splitTitle = (rawTitle: string) => {
	const idx = rawTitle.includes('：') ? rawTitle.indexOf('：') : rawTitle.indexOf(':');
	if (idx === -1) return { head: rawTitle, tail: null as string | null };
	return { head: rawTitle.slice(0, idx + 1), tail: rawTitle.slice(idx + 1).trim() };
};

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
}).format(pubDate);

const normalizeCategory = (raw?: string) => {
	if (!raw) return '随笔';
	const map: Record<string, string> = {
		Essay: '随笔',
		Essays: '随笔',
		Note: '笔记',
		Notes: '笔记',
		Diary: '日记',
		Life: '生活',
	};
	if (map[raw]) return map[raw];
	if (/^[A-Za-z0-9 _-]+$/.test(raw)) return '随笔';
	return raw;
};
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<header class="relative w-full h-[60vh] md:h-[70vh] overflow-hidden">
			<Image
				src={heroImage ?? FallbackImage}
				alt=""
				class="w-full h-full object-cover"
				width={1920}
				height={1080}
			/>
			<div class="absolute bottom-0 left-0 w-full max-w-6xl mx-auto px-6 md:px-10 lg:px-16 pb-16">
				<div
					class="inline-block px-4 py-1.5 rounded-full font-label text-[10px] font-bold tracking-[0.2em] mb-8 bg-primary-container text-on-primary-container"
				>
					{normalizeCategory(category)}
				</div>
				<h1
					class="text-4xl md:text-6xl lg:text-7xl font-headline font-extrabold text-white tracking-tighter leading-[1.1] max-w-4xl drop-shadow-sm"
				>
					{
						(() => {
							const { head, tail } = splitTitle(title);
							if (!tail) return head;
							return (
								<>
									{head}
									<br />
									<span class="italic text-primary">{tail}</span>
								</>
							);
						})()
					}
				</h1>
				<div class="mt-10 flex items-center gap-8 font-label text-zinc-500">
					<div class="flex items-center gap-2.5">
						<span class="material-symbols-outlined text-sm opacity-60">calendar_today</span>
						<span class="text-xs font-semibold tracking-wider">{formattedDate}</span>
					</div>
					<div class="flex items-center gap-2.5">
						<span class="material-symbols-outlined text-sm opacity-60">visibility</span>
						<span class="text-xs font-semibold tracking-wider">访问量 {views}</span>
					</div>
				</div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto px-6 md:px-10 lg:px-16 pt-24 pb-32">
			<div class="w-full mx-auto bg-surface-container-lowest rounded-3xl shadow-deepElevation p-10 md:p-20 mb-20">
				<article>
					<p class="text-2xl md:text-3xl font-light text-zinc-600 leading-relaxed font-headline mb-16">
						{description}
					</p>
					<div class="article-prose space-y-10 text-lg md:text-xl leading-[1.9] text-zinc-800 font-light">
						<slot />
					</div>
				</article>
			</div>

			{
				(prev || next) && (
					<section class="w-full mx-auto mt-32 pt-16 border-t border-zinc-100">
						<div class="flex flex-col md:flex-row justify-between gap-8">
							{prev ? (
								<a
									class="group flex-1 p-8 rounded-2xl bg-surface-container-lowest hover:bg-primary-container/40 transition-all flex items-center gap-6 shadow-editorial hover:shadow-deep3d"
									href={`/blog/${prev.id}/`}
								>
									<span class="material-symbols-outlined text-3xl transition-transform group-hover:-translate-x-2 text-primary">
										arrow_back
									</span>
									<div>
										<span class="text-[10px] font-label font-bold text-zinc-500 tracking-[0.2em]">
											上一篇
										</span>
										<h4 class="text-lg font-headline font-bold mt-1 transition-colors group-hover:text-primary">
											{prev.title}
										</h4>
									</div>
								</a>
							) : (
								<div class="flex-1" />
							)}

							{next ? (
								<a
									class="group flex-1 p-8 rounded-2xl bg-surface-container-lowest hover:bg-primary-container/40 transition-all flex items-center justify-end gap-6 text-right shadow-editorial hover:shadow-deep3d"
									href={`/blog/${next.id}/`}
								>
									<div>
										<span class="text-[10px] font-label font-bold text-zinc-500 tracking-[0.2em]">
											下一篇
										</span>
										<h4 class="text-lg font-headline font-bold mt-1 transition-colors group-hover:text-primary">
											{next.title}
										</h4>
									</div>
									<span class="material-symbols-outlined text-3xl transition-transform group-hover:translate-x-2 text-primary">
										arrow_forward
									</span>
								</a>
							) : (
								<div class="flex-1" />
							)}
						</div>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
